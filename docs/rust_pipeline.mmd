```mermaid
%%{init: {'theme': 'base', 'themeVariables': { 'primaryColor': '#e1f5fe', 'primaryTextColor': '#01579b', 'primaryBorderColor': '#0288d1', 'lineColor': '#0288d1', 'secondaryColor': '#fff3e0', 'tertiaryColor': '#e8f5e9'}}}%%

flowchart TB
    subgraph Entry["📦 Public API Entry Points"]
        direction TB
        detect["🔍 detect()<br/>Single best result"]
        detect_all["📋 detect_all()<br/>All candidates"]
        universal["🔄 UniversalDetector<br/>Streaming feed/close"]
    end

    subgraph Orchestrator["⚙️ Pipeline Orchestrator"]
        direction TB
        run_pipeline["run_pipeline(data, era, max_bytes)"]
        ctx["PipelineContext<br/>{analysis_cache, mb_scores, mb_coverage}"]
    end

    subgraph Stage0["🚀 Stage 0: Early Deterministic Detection"]
        direction TB
        bom["🔖 BOM Detection<br/>UTF-8/16/32 BOM → confidence 1.0"]
        utf1632["📊 UTF-16/32 Patterns<br/>Null-byte analysis"]
        binary["🗑️ Binary Detection<br/>Null bytes / control chars"]
        escape["⏏️ Escape Sequences<br/>ISO-2022, HZ-GB-2312, UTF-7"]
    end

    subgraph Stage1["📄 Stage 1: Markup & Basic Text"]
        direction TB
        markup["🏷️ Markup Charset<br/>&lt;meta charset&gt; / &lt;?xml encoding&gt;"]
        ascii["🔤 ASCII Check<br/>Pure 7-bit detection"]
        utf8["✓ UTF-8 Validation<br/>Structural multi-byte check"]
    end

    subgraph Stage2["🔧 Stage 2: Structural Analysis"]
        direction TB
        validity["✅ Byte Validity Filtering<br/>Eliminate invalid encodings"]
        cjk_gate["🚪 CJK Gating<br/>Multi-byte structure requirements"]
        structural["📐 Structural Probing<br/>Score multi-byte encoding fit"]
        threshold_check{"Structural score ≥ 0.85?"}
    end

    subgraph Stage3["📊 Stage 3: Statistical Analysis"]
        direction TB
        statistical["📈 Bigram Model Scoring<br/>Frequency analysis"]
        confusion["🎯 Confusion Resolution<br/>Resolve ambiguity groups"]
        niche_demote["📉 Niche Latin Demotion<br/>Promote common encodings"]
    end

    subgraph Results["📤 Results"]
        direction TB
        result_vec["Vec&lt;DetectionResult&gt;<br/>[encoding, confidence, language]"]
    end

    %% Main flow connections
    detect --> run_pipeline
    detect_all --> run_pipeline
    universal -.-> run_pipeline

    run_pipeline --> ctx
    run_pipeline --> Stage0

    %% Stage 0 flow
    bom -->|"BOM found"| result_vec
    bom -->|"No BOM"| utf1632
    utf1632 -->|"Pattern match"| result_vec
    utf1632 -->|"No match"| binary
    binary -->|"Is binary"| result_vec
    binary -->|"Is text"| escape
    escape -->|"Escape encoding found"| result_vec
    escape -->|"No escape seq"| Stage1

    %% Stage 1 flow
    markup -->|"Charset found"| result_vec
    markup -->|"No markup"| ascii
    ascii -->|"Pure ASCII"| result_vec
    ascii -->|"Has high bytes"| utf8
    utf8 -->|"Valid UTF-8"| result_vec
    utf8 -->|"Invalid/not UTF-8"| Stage2

    %% Stage 2 flow
    validity --> cjk_gate
    cjk_gate -->|"CJK eliminated"| fallback["windows-1252 @ 0.10"]
    cjk_gate -->|"Candidates remain"| structural
    structural --> threshold_check
    threshold_check -->|"Yes: High confidence"| score_structural["score_structural_candidates()"]
    threshold_check -->|"No: Continue"| Stage3

    %% Stage 3 flow
    statistical --> confusion
    confusion --> niche_demote
    score_structural --> confusion

    niche_demote --> result_vec
    fallback --> result_vec

    %% Styling
    classDef entry fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    classDef stage0 fill:#ffebee,stroke:#c62828,stroke-width:2px
    classDef stage1 fill:#fff3e0,stroke:#ef6c00,stroke-width:2px
    classDef stage2 fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px
    classDef stage3 fill:#f3e5f5,stroke:#6a1b9a,stroke-width:2px
    classDef result fill:#e0f2f1,stroke:#00695c,stroke-width:3px
    classDef decision fill:#fff9c4,stroke:#f57f17,stroke-width:2px,shape:diamond
    classDef fallback fill:#eceff1,stroke:#455a64,stroke-width:1px

    class detect,detect_all,universal entry
    class bom,utf1632,binary,escape stage0
    class markup,ascii,utf8 stage1
    class validity,cjk_gate,structural stage2
    class statistical,confusion,niche_demote stage3
    class result_vec result
    class threshold_check decision
    class fallback fallback
